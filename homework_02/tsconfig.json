{
  "compilerOptions": {
    "sourceMap": true,
    // показує ts вмісто js в console
    // "noEmitOnError": true,
    // js не генерується при помилці
    "target": "es6",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./javascript",
    "rootDir": "./src",
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "javascript"]
}
